<script>
document.querySelectorAll('.filter-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
        this.classList.add('active');
        var filter = this.getAttribute('data-filter');
        document.querySelectorAll('.program-card-full').forEach(function(card) {
            card.style.display = (filter === 'all' || card.getAttribute('data-category') === filter) ? 'flex' : 'none';
        });
    });
});

(function() {
    var pc = window.pageContent || {};
    document.querySelectorAll('[data-c]').forEach(function(el) {
        var key = el.getAttribute('data-c');
        if (pc[key]) el.innerHTML = pc[key];
    });
    document.querySelectorAll('[data-ch]').forEach(function(el) {
        var key = el.getAttribute('data-ch');
        if (pc[key]) el.innerHTML = pc[key];
    });
})();
</script>
