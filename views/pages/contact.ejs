<!-- Page Hero -->
<section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="container">
        <h1 data-ch="hero-title">Get in <span class="text-gradient">Touch</span></h1>
        <p data-c="hero-desc">Have questions? Our education experts are here to help you.</p>
    </div>
</section>

<section class="contact-page">
    <div class="container">
        <div class="contact-grid">
            <div class="contact-info">
                <h2 data-ch="info-title">Let's Start a <span class="text-gradient">Conversation</span></h2>
                <p data-c="info-desc">Select your role and fill out the form. Our education experts will get back to you within 24 hours.</p>
                <div class="contact-details">
                    <div class="contact-detail"><div class="contact-detail-icon"><i class="fas fa-phone-alt"></i></div><div><h4 data-c="phone-label">Call Us</h4><a href="tel:+918769923339" data-c="phone-value">+91 87699 23339</a></div></div>
                    <div class="contact-detail"><div class="contact-detail-icon"><i class="fas fa-envelope"></i></div><div><h4 data-c="email-label">Email Us</h4><a href="mailto:info@advancelearningpath.com" data-c="email-value">info@advancelearningpath.com</a></div></div>
                    <div class="contact-detail"><div class="contact-detail-icon"><i class="fas fa-map-marker-alt"></i></div><div><h4 data-c="location-label">Visit Us</h4><p data-c="location-value">Gurugram, Haryana, India</p></div></div>
                    <div class="contact-detail"><div class="contact-detail-icon"><i class="fas fa-clock"></i></div><div><h4 data-c="hours-label">Working Hours</h4><p data-c="hours-value">Mon - Sat: 10:00 AM - 7:00 PM</p></div></div>
                </div>
            </div>
            <div class="contact-form-wrapper">
                <form class="contact-form" id="contactForm">
                    <h3 data-c="form-title">Contact Us</h3>
                    <div class="form-group"><label>I am a... *</label>
                        <select name="contact_type" id="contactRole" required>
                            <option value="">Select your role</option>
                            <option value="Ex Employee">Ex Employee</option>
                            <option value="Current Employee">Current Employee</option>
                            <option value="Ex Student">Ex Student</option>
                            <option value="Current Student">Current Student</option>
                        </select>
                    </div>
                    <div class="form-row">
                        <div class="form-group"><label>Full Name *</label><input type="text" name="name" placeholder="Your full name" required></div>
                        <div class="form-group"><label>Email *</label><input type="email" name="email" placeholder="Your email" required></div>
                    </div>
                    <div class="form-group"><label>Phone *</label><input type="tel" name="phone" placeholder="Your phone number" required></div>
                    <div id="studentFields" style="display:none;">
                        <div class="form-group"><label>Program Interest</label>
                            <select name="program">
                                <option value="">Select Program</option>
                                <option>Online MBA</option><option>Online MCA</option><option>Online MCom</option>
                                <option>Online MA</option><option>Online PGDM</option><option>Online BBA</option>
                                <option>Online BCA</option><option>Online BCom</option><option>Online BA</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group"><label>Message *</label><textarea name="message" id="contactMessage" rows="4" placeholder="Tell us how we can help you..." required></textarea></div>
                    <label class="consent-check"><input type="checkbox" required><span>I consent to be contacted by Advance Learning Path via Call, SMS, Email, or WhatsApp.</span></label>
                    <button type="submit" class="btn btn-primary btn-block">Send Message <i class="fas fa-paper-plane"></i></button>
                </form>
            </div>
        </div>
    </div>
</section>

<script>
document.getElementById('contactRole').addEventListener('change', function() {
    var studentFields = document.getElementById('studentFields');
    if (this.value === 'student') {
        studentFields.style.display = 'block';
    } else {
        studentFields.style.display = 'none';
    }
});

document.getElementById('contactForm').addEventListener('submit', function(e) {
    e.preventDefault();
    var btn = this.querySelector('button[type="submit"]');
    var orig = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
    btn.disabled = true;
    fetch('/api/leads', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            name: this.name.value, 
            email: this.email.value, 
            phone: this.phone.value,
            contact_type: this.contact_type.value,
            course: this.program ? this.program.value : '',
            message: this.message.value, 
            source: 'contact_us'
        })
    }).then(function(r) { return r.json(); }).then(function(data) {
        btn.innerHTML = '<i class="fas fa-check"></i> Sent Successfully!';
        btn.style.background = 'var(--secondary)';
        setTimeout(function() { btn.innerHTML = orig; btn.style.background = ''; btn.disabled = false; }, 3000);
        document.getElementById('contactForm').reset();
    }).catch(function() { btn.innerHTML = orig; btn.disabled = false; });
});

(function() {
    var pc = window.pageContent || {};
    document.querySelectorAll('[data-c]').forEach(function(el) {
        var key = el.getAttribute('data-c');
        if (pc[key]) el.innerHTML = pc[key];
    });
    document.querySelectorAll('[data-ch]').forEach(function(el) {
        var key = el.getAttribute('data-ch');
        if (pc[key]) el.innerHTML = pc[key];
    });
})();
</script>
